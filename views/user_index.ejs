<%-  include ('layouts/header.ejs') %>
<div class="container">
    <h2><%= title %></h2>
    <h1>Register to Begin!</h1>
    <form action="/register" method="post">
       <div class="form-group">
        <label >First Name:</label>
        <input type="text" class="form-control" id="driver_id" placeholder="Enter First Name" name="cus_fname" required>
      </div>
      <div class="form-group">
        <label >Last Name:</label>
        <input type="car_id" class="form-control" id="car_id" placeholder="Enter Last Name" name="cus_lname" required>
      </div>
      <div class="form-group">
        <label>Region:</label>
        <input type="text" class="form-control" id="reg_id" placeholder="Enter Region 1 - 10" name="reg_id" required>
      </div>
      <div class="form-group">
        <label >Destination Address:</label>
        <input type="text" class="form-control" id="l_name" placeholder="Enter Last Name" name="dest_address" required>
      </div>
      <button type="submit" class="btn btn-primary" onclick="checkRegion()">Submit</button>
    </form>
  </div>

<script>
    function checkRegion() {
      let x = document.getElementById("reg_id").value;
      // If x is Not a Number or less than one or greater than 10
      let text;
      if (isNaN(x) || x < 1 || x > 10) {
        alert("REGION must be between 1 and 10!");
        jQuery("form").submit(function(e){
        e.preventDefault();  
          });
      };
    };
</script>
    
