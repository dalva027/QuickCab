<%-  include ('layouts/header.ejs') %>
  <body>
  
      <div class="container"> 
        <h1>
            <%= title %>
        </h1>
        <div>
            <a href="/driver_index" class="btn btn-sm btn-primary">GO Back</a>
        </br></br>
        <table class="table table-striped table-dark">
            <thead>
              <tr>
                <th scope="col">Trip ID</th>
                <th scope="col">Driver ID</th>
                <th scope="col">Customer ID</th>
                <th scope="col">Region ID</th>
                <th scope="col">L Name</th>
                <th scope="col">F Name</th>
                <th scope="col">Miles</th>
                <th scope="col">Gas Cost</th>
                <th scope="col">Region Fee</th>
                <th scope="col">Tax</th>
                <th scope="col">Total Cost</th>
              </tr>
            </thead>
            <tbody>
              <% invoice.forEach(function(invoice){ %>
              <tr>
                <th scope="row"><%= invoice.trip_id%></th>
                <td><%= invoice.driver_id %></td>
                <td><%= invoice.cus_id %></td>
                <td><%= invoice.reg_id %></td>
                <td><%= invoice.cus_lname %></td>
                <td><%= invoice.cus_fname %></td>
                <td><%= invoice.trip_miles %></td>
                <td><%= invoice.cost_gas %></td>
                <td><%= invoice.fee %></td>
                <td><%= invoice.tax %></td>
                <td><%= invoice.total_cost %></td>

              </tr>
              <% }); %>
            </tbody>
          </table>
      </div>
    </body>
  </html>
<%- include('layouts/footer.ejs') %>